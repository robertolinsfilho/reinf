{
  "name": "EFD REINF",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/var/www/html",
  "forwardPorts": [80, 8080, 3306],
  "portsAttributes": {
    "80": {
      "label": "EFD REINF Web",
      "onAutoForward": "openBrowser"
    },
    "8080": {
      "label": "phpMyAdmin",
      "onAutoForward": "notify"
    },
    "3306": {
      "label": "MySQL"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "xdebug.php-debug",
        "mikestead.dotenv",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "cd /var/www/html && composer install --no-interaction --optimize-autoloader"
}