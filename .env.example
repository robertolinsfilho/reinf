APP_NAME="STHEPSON"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

# Crypto de certificados A1 — gere com: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=efd_reinf
DB_USERNAME=reinf_user
DB_PASSWORD=troque_esta_senha_db
MYSQL_ROOT_PASSWORD=troque_esta_senha_root

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log

# EFD-Reinf
# 1 = Produção (CUIDADO!) | 2 = Homologação (padrão)
REINF_TP_AMB=2
REINF_CERT_PATH=/var/www/html/storage/certs/
REINF_CERT_PASS=

# 1 = permite envio simulado sem certificado (nunca em produção)
ALLOW_SIMULATED_TRANSMISSION=0
