APP_NAME="STHEPSON"
APP_URL=http://localhost
# local | production — em production APP_SECRET fraco bloqueia o boot
APP_ENV=local
# Gere com: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
APP_SECRET=

DB_HOST=db
DB_PORT=3306
DB_NAME=efd_reinf
DB_USER=reinf_user
DB_PASS=troque_esta_senha_db
MYSQL_ROOT_PASSWORD=troque_esta_senha_root

# EFD-Reinf
# 1 = Produção (CUIDADO!) | 2 = Homologação (padrão)
REINF_TP_AMB=2
REINF_CERT_PATH=/var/www/html/storage/certs/
REINF_CERT_PASS=

# 1 = permite envio simulado sem certificado (nunca em produção)
ALLOW_SIMULATED_TRANSMISSION=0
