{
    "name": "reinf/efd-reinf-web",
    "description": "Sistema EFD-Reinf Web - PHP + Docker",
    "type": "project",
    "require": {
        "php": "^8.2",
        "ext-openssl": "*",
        "ext-dom": "*",
        "ext-curl": "*",
        "ext-simplexml": "*",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}